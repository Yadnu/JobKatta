generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum PlanType {
  FREE
  PREMIUM
  BASIC
  STANDARD
  ANNUAL
}

enum JobStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  EXPIRED
  REJECTED
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  VIEWED
  SHORTLISTED
  INTERVIEWING
  HIRED
  REJECTED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  FREELANCE
  CONTRACT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  mobile           String?   @unique
  passwordHash     String?
  role             Role
  isEmailVerified  Boolean   @default(false)
  isMobileVerified Boolean   @default(false)
  isActive         Boolean   @default(true)
  isSuspended      Boolean   @default(false)
  lastLoginAt      DateTime?
  emailVerifyToken String?
  refreshToken     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  candidate      Candidate?
  employer       Employer?
  admin          Admin?
  supportTickets SupportTicket[]
  flagReports    FlagReport[]
}

model Candidate {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName           String
  lastName            String
  photoUrl            String?
  gender              String?
  dob                 DateTime?
  mobile              String?
  email               String?
  addressLine1        String?
  city                String
  state               String
  pincode             String?
  resumeUrl           String?
  portfolioUrl        String?
  linkedinUrl         String?
  githubUrl           String?
  bio                 String?   @db.Text
  isFresher           Boolean   @default(true)
  totalExperienceYrs  Float     @default(0)
  openToWork          Boolean   @default(true)
  profileComplete     Int       @default(0)
  preferredRoles      String?
  preferredIndustries String?
  preferredCities     String?
  preferredEmpType    String?
  expectedSalaryMin   Int?
  expectedSalaryMax   Int?
  planType            PlanType  @default(FREE)
  planExpiresAt       DateTime?
  appCountThisMonth   Int       @default(0)
  appCountReset       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  educations     Education[]
  experiences    Experience[]
  skills         CandidateSkill[]
  applications   Application[]
  savedJobs      SavedJob[]
  recentlyViewed RecentlyViewedJob[]
  subscriptions  Subscription[]
  emailAlerts    EmailAlert[]
}

model Education {
  id           String    @id @default(cuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  degree       String
  fieldOfStudy String?
  institution  String
  board        String?
  percentage   Float?
  startYear    Int
  endYear      Int?
  isCurrently  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Experience {
  id             String          @id @default(cuid())
  candidateId    String
  candidate      Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobTitle       String
  companyName    String
  city           String?
  employmentType EmploymentType?
  startDate      DateTime
  endDate        DateTime?
  isCurrent      Boolean         @default(false)
  description    String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Skill {
  id         String           @id @default(cuid())
  name       String           @unique
  category   String?
  createdAt  DateTime         @default(now())
  candidates CandidateSkill[]
  jobs       JobSkill[]
}

model CandidateSkill {
  candidateId String
  skillId     String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill       Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateId, skillId])
}

model Employer {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  logoUrl       String?
  companyEmail  String?
  contactNumber String?
  website       String?
  industry      String?
  companySize   String?
  foundedYear   Int?
  description   String?   @db.Text
  addressLine1  String?
  city          String
  state         String
  pincode       String?
  gstNumber     String?
  cinNumber     String?
  hrName        String?
  hrDesignation String?
  isVerified    Boolean   @default(false)
  planType      PlanType  @default(FREE)
  planExpiresAt DateTime?
  activeJobLimit Int      @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  jobs          Job[]
  subscriptions Subscription[]
}

model Job {
  id                  String         @id @default(cuid())
  employerId          String
  employer            Employer       @relation(fields: [employerId], references: [id], onDelete: Cascade)
  title               String
  description         String         @db.Text
  requirements        String?        @db.Text
  hiringProcess       String?        @db.Text
  category            String
  employmentType      EmploymentType
  salaryMin           Int?
  salaryMax           Int?
  isSalaryNegotiable  Boolean        @default(false)
  hideSalary          Boolean        @default(false)
  openings            Int            @default(1)
  experienceMin       Int            @default(0)
  experienceMax       Int?
  qualification       String?
  shiftTiming         String?
  city                String
  state               String
  pincode             String?
  isRemote            Boolean        @default(false)
  applicationDeadline DateTime?
  status              JobStatus      @default(PENDING_APPROVAL)
  approvedAt          DateTime?
  approvedBy          String?
  rejectionReason     String?
  isFeatured          Boolean        @default(false)
  isPriority          Boolean        @default(false)
  viewCount           Int            @default(0)
  applicationCount    Int            @default(0)
  scheduledAt         DateTime?
  expiresAt           DateTime?
  renewalReminderSent Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  skills         JobSkill[]
  applications   Application[]
  savedBy        SavedJob[]
  recentlyViewed RecentlyViewedJob[]
}

model JobSkill {
  jobId   String
  skillId String
  job     Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model Application {
  id              String            @id @default(cuid())
  candidateId     String
  jobId           String
  candidate       Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status          ApplicationStatus @default(APPLIED)
  coverNote       String?           @db.Text
  resumeUrl       String?
  internalNote    String?           @db.Text
  followUpDate    DateTime?
  contactUnlocked Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([candidateId, jobId])
}

model SavedJob {
  candidateId String
  jobId       String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([candidateId, jobId])
}

model RecentlyViewedJob {
  candidateId String
  jobId       String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  viewedAt    DateTime  @default(now())

  @@id([candidateId, jobId])
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String
  candidateId       String?
  employerId        String?
  candidate         Candidate? @relation(fields: [candidateId], references: [id])
  employer          Employer?  @relation(fields: [employerId], references: [id])
  planType          PlanType
  amount            Int
  currency          String    @default("INR")
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  status            String    @default("pending")
  startsAt          DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  subject    String
  message    String       @db.Text
  status     TicketStatus @default(OPEN)
  adminReply String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model FlagReport {
  id         String   @id @default(cuid())
  reportedBy String
  user       User     @relation(fields: [reportedBy], references: [id])
  targetType String
  targetId   String
  reason     String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailAlert {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  keywords    String?
  city        String?
  jobType     String?
  isActive    Boolean   @default(true)
  lastSentAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
