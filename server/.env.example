# Neon: use the pooled connection string for the app, direct for migrations
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="minimum-64-character-random-secret-key-here-replace-with-real-value"
JWT_REFRESH_SECRET="another-64-character-random-refresh-secret-replace-with-real-value"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

PORT=5000
NODE_ENV=development

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=brevo_api_key
EMAIL_FROM="Job Katta <noreply@jobkatta.in>"

RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

MSG91_AUTH_KEY=your_msg91_key
MSG91_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=JOBKTA

UPLOAD_PATH=/var/www/jobkatta/uploads
BASE_URL=https://jobkatta.in
CLIENT_URL=http://localhost:3000

CORS_ORIGIN=http://localhost:3000
